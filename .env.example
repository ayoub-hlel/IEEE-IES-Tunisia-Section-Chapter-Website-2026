# ============================================================================
# IEEE IES Tunisia Section — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the values.
# ============================================================================

# UploadThing — for photo management
# Get your token from: https://uploadthing.com/dashboard
UPLOADTHING_TOKEN=

# Admin API — simple bearer token for protecting admin endpoints
# Generate a random string: openssl rand -hex 32
ADMIN_TOKEN=

# Database path (optional, defaults to ./db/ies-tunisia.db)
# DATABASE_PATH=./db/ies-tunisia.db
